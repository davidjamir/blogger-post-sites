# MongoDB
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=databases

# Google OAuth 2.0 — Ứng dụng web (Web application), URI chuyển hướng:
#   http://localhost:3000/api/auth/google/callback
#   https://<domain>/api/auth/google/callback
# @see https://developers.google.com/identity/protocols/oauth2/web-server?hl=vi#node.js_2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bắt buộc cho cron: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Tuỳ chọn: giới hạn số tài khoản mỗi lần GET /api/cron/refresh-tokens (mặc định 200, tối đa 5000)
# CRON_MAX_ACCOUNTS=200

# Tuỳ chọn: số bài tối đa mỗi lần GET /api/cron/publish-posts (mặc định 10, tối đa 100)
# CRON_MAX_PUBLISH_PER_RUN=10

NEXT_PUBLIC_APP_URL=http://localhost:3000
# OAUTH_DEBUG_LOG=true
